{
  "apiType": "stageMode",
  "buildOption": {
  },
  "buildOptionSet": [
    {
      "name": "release",
      "arkOptions": {
        "obfuscation": {
          "ruleOptions": {
            "enable": true,
            "files": [
              "./obfuscation-rules.txt"
            ]
          }
        }
      }
    },
  ],
  "targets": [
    {
      "name": "default"
    },
    {
      "name": "noise_meter_pro",
      "runtimeOS": "HarmonyOS",
      "source": {
        "pages": [
          "pages/Index",
        ],
        "sourceRoots": [
          "./src/main"
        ]
      },
      "resource": {
        "directories": [
          "./src/main/resources"
        ]
      }
    }
  ]
}