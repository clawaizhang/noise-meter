{
  "apiType": "stageMode",
  "buildOption": {
    "arkOptions": {
    "integratedHsp": true
  }
  },
  "buildOptionSet": [
    {
      "name": "release",
      "arkOptions": {
        "obfuscation": {
          "ruleOptions": {
            "enable": false,
            "files": [
              "./obfuscation-rules.txt"
            ]
          }
        }
      },
    },
  ],
  "targets": [
    {
      "name": "default",
      "runtimeOS": "HarmonyOS"
    },
    {
      "name": "noise_meter",
      "runtimeOS": "HarmonyOS"
    },
    {
      "name": "file_vault",
      "runtimeOS": "HarmonyOS"
    }
  ]
}